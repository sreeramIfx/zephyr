/*
 * DTS overlay applied to the MCUBoot bootloader image only.
 *
 * Overrides the chosen code-partition to boot_partition so that
 * MCUBoot is linked at the RRAM address where the extended boot
 * expects it (0x22011000). All flash slot geometry (slot0..slot5
 * across CBUS-S, CBUS-NS and SAHB) is defined in
 * kit_pse84_eval_memory_map.dtsi so that the bootloader inherits
 * the same view used by the SPE / NSPE / CM55 builds.
 */
/ {
	chosen {
		zephyr,code-partition = &boot_partition;
		zephyr,flash = &rram0;
	};
};
